# Copie este arquivo para ".env" e preencha com seus valores reais.
# O arquivo ".env" NUNCA deve ser enviado ao GitHub (já está no .gitignore).

# Credenciais do e-mail administrativo (Gmail + senha de app, não a senha normal da conta)
EMAIL_ADM=seuemail@gmail.com
EMAIL_PASSWORD=sua-senha-de-app-aqui

# URL pública do backend depois do deploy (ex: https://trilha-do-eleitor.onrender.com)
# Em desenvolvimento local, pode deixar como está:
BACKEND_URL=http://127.0.0.1:1234

# URL(s) do frontend permitidas pelo CORS, separadas por vírgula
# Em desenvolvimento local, pode deixar como está:
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# String de conexão do banco de dados.
# Em desenvolvimento local, pode deixar em branco (vai usar SQLite automaticamente).
# Em produção, cole aqui a connection string do seu Postgres (ex: do Neon).
DATABASE_URL=

# Credenciais do Cloudinary (https://cloudinary.com), usado para armazenar fotos
# de perfil e imagens de conteúdo enviadas pelos usuários. Crie uma conta gratuita,
# acesse o Dashboard e copie os 3 valores abaixo.
# Se deixar em branco, o sistema usa o disco local (uploads/), o que é suficiente
# apenas em desenvolvimento — em produção as imagens seriam perdidas a cada deploy.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
